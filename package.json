{
  "name": "omnidrive",
  "version": "1.0.0",
  "description": "OmniDrive - Kenya's Premier Vehicle Marketplace - Full-stack application with MPesa integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server-improved": "node server-improved.js",
    "dev": "nodemon server.js",
    "dev-improved": "nodemon server-improved.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deploy": "railway up"
  },
  "keywords": [
    "omnidrive",
    "vehicle marketplace",
    "mpesa",
    "kenya",
    "e-commerce"
  ],
  "author": "OmniDrive",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "axios": "^1.15.0",
    "better-sqlite3": "^12.8.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.6",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "*.js",
      "config/**/*.js",
      "middleware/**/*.js",
      "!node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  }
}
