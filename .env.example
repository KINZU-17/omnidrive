# Environment
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# Redis Caching & Session Store
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
SESSION_SECRET=your-session-secret-change-in-production

# MPesa Daraja API
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://your-backend-url.com/api/mpesa/callback

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin Authentication
ADMIN_KEY=your-secure-admin-key-change-in-production

# Web Push Notifications
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Redis Cache (Optional, for Phase 2)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Database
DB_PATH=./omnidrive.db

# Security
CORS_ORIGIN=http://localhost:3000,https://omnidrive.co.ke
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# JWT (for future auth expansion)
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY=7d
